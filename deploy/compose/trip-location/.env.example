# =============================================================================
# Trip/Location Production Stack — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running:
#   docker compose -f docker-compose.prod.yml up -d
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=lojinext
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
TRIP_DB_NAME=trip_service
LOCATION_DB_NAME=location_service
# POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redpanda (Kafka)
# ---------------------------------------------------------------------------
# REDPANDA_EXTERNAL_PORT=19092

# ---------------------------------------------------------------------------
# Trip Service
# ---------------------------------------------------------------------------
TRIP_AUTH_JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_BYTES
TRIP_AUTH_JWT_ALGORITHM=HS256
TRIP_BROKER_TYPE=kafka
# TRIP_KAFKA_SECURITY_PROTOCOL=SASL_SSL
# TRIP_KAFKA_SASL_MECHANISM=PLAIN
# TRIP_KAFKA_SASL_USERNAME=
# TRIP_KAFKA_SASL_PASSWORD=
TRIP_ALLOW_PLAINTEXT_IN_PROD=false

# Trip Service — Downstream dependencies
# TRIP_FLEET_SERVICE_URL=http://fleet-api:8102
# TRIP_LOCATION_SERVICE_URL=http://location-api:8103
# TRIP_DEPENDENCY_TIMEOUT_SECONDS=5.0

# Trip Service — Worker tuning
# TRIP_ENRICHMENT_CLAIM_TTL_SECONDS=300
# TRIP_ENRICHMENT_MAX_ATTEMPTS=5
# TRIP_ENRICHMENT_POLL_INTERVAL_SECONDS=10
# TRIP_WORKER_HEARTBEAT_TIMEOUT_SECONDS=30
# TRIP_OUTBOX_RELAY_POLL_INTERVAL_SECONDS=5
# TRIP_OUTBOX_RELAY_CLAIM_TTL_SECONDS=60

# ---------------------------------------------------------------------------
# Location Service
# ---------------------------------------------------------------------------
LOCATION_AUTH_JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_BYTES
LOCATION_AUTH_JWT_ALGORITHM=HS256
LOCATION_MAPBOX_API_KEY=CHANGE_ME
LOCATION_ORS_API_KEY=CHANGE_ME
LOCATION_ENABLE_ORS_VALIDATION=true
# LOCATION_ORS_BASE_URL=https://api.openrouteservice.org/v2/directions/driving-hgv

# Location Service — Worker tuning
# LOCATION_PROCESSING_POLL_INTERVAL_SECONDS=5.0
# LOCATION_PROCESSING_CLAIM_TTL_SECONDS=300
# LOCATION_WORKER_HEARTBEAT_TIMEOUT_SECONDS=60
# LOCATION_RUN_STUCK_SLA_MINUTES=30

# Location Service — Provider tuning
# LOCATION_PROVIDER_TIMEOUT_MS=4000
# LOCATION_PROVIDER_RETRY_MAX=3
# LOCATION_PROVIDER_PROBE_TTL_SECONDS=30

# ---------------------------------------------------------------------------
# Nginx
# ---------------------------------------------------------------------------
# NGINX_PORT=80

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME
