# Postgres
POSTGRES_USER=lojinext
POSTGRES_PASSWORD=lojinext_secure_password
POSTGRES_PORT=5432

# DB Names
IDENTITY_DB_NAME=identity_service
TRIP_DB_NAME=trip_service
LOCATION_DB_NAME=location_service
DRIVER_DB_NAME=driver_service
FLEET_DB_NAME=fleet_service

# Auth Common
AUTH_ISSUER=lojinext-platform
AUTH_AUDIENCE=lojinext-platform
LOCATION_IGNORE_PROVIDER_HEALTH=true
IDENTITY_AUTH_STRICT_AUDIENCE_CHECK=false

# Identity
IDENTITY_KEY_ENCRYPTION_KEY_B64=your_base64_encryption_key_here
IDENTITY_KEY_ENCRYPTION_KEY_VERSION=1
IDENTITY_BOOTSTRAP_SUPERADMIN_PASSWORD=change-me-immediately

# Service Secrets (Identity <-> Services)
TRIP_SERVICE_CLIENT_SECRET=trip-secret-123
LOCATION_SERVICE_CLIENT_SECRET=location-secret-123
DRIVER_SERVICE_CLIENT_SECRET=driver-secret-123
FLEET_SERVICE_CLIENT_SECRET=fleet-secret-123

# Kafka / Redpanda
REDPANDA_EXTERNAL_PORT=19092

# Gateway / Observability
NGINX_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
