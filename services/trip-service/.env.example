# Trip Service Environment Variables
# Copy this file to .env and update values as needed.

# --- Service Identity (V8 Section 2) ---
TRIP_SERVICE_NAME=trip-service
TRIP_SERVICE_PORT=8101
TRIP_ENVIRONMENT=dev

# --- Database ---
TRIP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trip_service

# --- External Service URLs (V8 Section 7) ---
TRIP_FLEET_SERVICE_URL=http://localhost:8102
TRIP_LOCATION_SERVICE_URL=http://localhost:8103
TRIP_DEPENDENCY_TIMEOUT_SECONDS=5.0

# --- Auth ---
# Bridge mode: set PLATFORM_JWT_SECRET and keep HS256.
# RS256 mode: set JWKS + service-token endpoint values and leave PLATFORM_JWT_SECRET empty.
PLATFORM_JWT_SECRET=
TRIP_AUTH_JWT_SECRET=trip-service-dev-secret-please-change-me-32b
TRIP_AUTH_JWT_ALGORITHM=HS256
TRIP_AUTH_ISSUER=lojinext-platform
TRIP_AUTH_AUDIENCE=lojinext-platform
TRIP_AUTH_PUBLIC_KEY=
TRIP_AUTH_PRIVATE_KEY=
TRIP_AUTH_JWKS_URL=
TRIP_AUTH_JWKS_CACHE_TTL_SECONDS=300
TRIP_AUTH_SERVICE_TOKEN_URL=
TRIP_AUTH_SERVICE_CLIENT_ID=trip-service
TRIP_AUTH_SERVICE_CLIENT_SECRET=
TRIP_ALLOW_LEGACY_ACTOR_HEADERS=false

# --- Enrichment Worker (V8 Section 13) ---
TRIP_ENRICHMENT_CLAIM_TTL_SECONDS=300
TRIP_ENRICHMENT_MAX_ATTEMPTS=5
TRIP_ENRICHMENT_POLL_INTERVAL_SECONDS=10
TRIP_WORKER_HEARTBEAT_TIMEOUT_SECONDS=30

# --- Outbox Relay (V8 Section 14) ---
TRIP_OUTBOX_RELAY_POLL_INTERVAL_SECONDS=5
TRIP_OUTBOX_RELAY_MAX_FAILURES=10

# --- Broker ---
TRIP_BROKER_TYPE=log
TRIP_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
TRIP_KAFKA_TOPIC=trip.events.v1
TRIP_KAFKA_CLIENT_ID=trip-service
TRIP_KAFKA_SECURITY_PROTOCOL=PLAINTEXT
TRIP_KAFKA_SASL_MECHANISM=
TRIP_KAFKA_SASL_USERNAME=
TRIP_KAFKA_SASL_PASSWORD=

# --- Idempotency (V8 Section 15) ---
TRIP_IDEMPOTENCY_RETENTION_HOURS=24
