# Driver Service — Environment Variables
# Copy to .env and fill in values

# Service
DRIVER_SERVICE_NAME=driver-service
DRIVER_SERVICE_PORT=8104
DRIVER_ENVIRONMENT=dev

# Database
DRIVER_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/driver_service

# Auth (CHANGE IN PRODUCTION)
DRIVER_AUTH_JWT_ALGORITHM=RS256
DRIVER_AUTH_ISSUER=lojinext-platform
DRIVER_AUTH_AUDIENCE=lojinext-platform
DRIVER_AUTH_PUBLIC_KEY=
DRIVER_AUTH_PRIVATE_KEY=
DRIVER_AUTH_JWKS_URL=http://localhost:8105/.well-known/jwks.json
DRIVER_AUTH_JWKS_CACHE_TTL_SECONDS=300
DRIVER_AUTH_SERVICE_AUDIENCE=lojinext-platform
DRIVER_AUTH_SERVICE_TOKEN_URL=http://localhost:8105/auth/v1/token/service
DRIVER_AUTH_SERVICE_CLIENT_ID=driver-service
DRIVER_AUTH_SERVICE_CLIENT_SECRET=

# Phone normalization
DRIVER_DEFAULT_PHONE_REGION=TR

# Feature flags
DRIVER_ENABLE_HARD_DELETE=false
DRIVER_ENABLE_MERGE_ENDPOINT=false

# Outbox
DRIVER_OUTBOX_PUBLISH_BATCH_SIZE=100
DRIVER_OUTBOX_RETRY_MAX=20
DRIVER_OUTBOX_WORKER_ENABLED=true
DRIVER_OUTBOX_POLL_INTERVAL_SECONDS=5

# Pagination
DRIVER_DEFAULT_PAGE_SIZE=50
DRIVER_MAX_PAGE_SIZE=200

# Dependencies
DRIVER_TRIP_SERVICE_BASE_URL=http://localhost:8101
DRIVER_DEPENDENCY_TIMEOUT_SECONDS=5.0

# Logging
DRIVER_LOG_MASK_PHONE=true

# Broker
# DRIVER_BROKER_TYPE=    (auto: prod=kafka, test=noop, dev=log)
DRIVER_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
DRIVER_KAFKA_TOPIC=driver.events.v1
DRIVER_KAFKA_CLIENT_ID=driver-service
DRIVER_KAFKA_SECURITY_PROTOCOL=PLAINTEXT
