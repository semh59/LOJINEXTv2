# Identity Service environment variables
# Copy to .env and fill in real values. Never commit .env.

IDENTITY_SERVICE_PORT=8105
IDENTITY_ENVIRONMENT=dev
IDENTITY_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/identity_service
IDENTITY_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

IDENTITY_AUTH_JWT_ALGORITHM=RS256
IDENTITY_AUTH_ISSUER=lojinext-platform
IDENTITY_AUTH_AUDIENCE=lojinext-platform
IDENTITY_KEY_ENCRYPTION_KEY_B64=
IDENTITY_KEY_ENCRYPTION_KEY_VERSION=
IDENTITY_ACCESS_TOKEN_TTL_SECONDS=900
IDENTITY_REFRESH_TOKEN_TTL_SECONDS=1209600
IDENTITY_SERVICE_TOKEN_TTL_SECONDS=300

IDENTITY_BOOTSTRAP_SUPERADMIN_USERNAME=superadmin
IDENTITY_BOOTSTRAP_SUPERADMIN_EMAIL=superadmin@example.com
IDENTITY_BOOTSTRAP_SUPERADMIN_PASSWORD=change-me-now
IDENTITY_SERVICE_CLIENTS=trip-service,location-service,driver-service,fleet-service
IDENTITY_SERVICE_CLIENT_SECRET__TRIP_SERVICE=
IDENTITY_SERVICE_CLIENT_SECRET__LOCATION_SERVICE=
IDENTITY_SERVICE_CLIENT_SECRET__DRIVER_SERVICE=
IDENTITY_SERVICE_CLIENT_SECRET__FLEET_SERVICE=
