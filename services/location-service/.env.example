# Location Service — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# --- Database ---
LOCATION_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/location_service

# --- Service ---
LOCATION_SERVICE_PORT=8103

# --- Mapbox (required) ---
LOCATION_MAPBOX_API_KEY=
LOCATION_MAPBOX_DIRECTIONS_BASE_URL=https://api.mapbox.com/directions/v5
LOCATION_MAPBOX_RASTER_BASE_URL=https://api.mapbox.com/v4

# --- ORS (optional, graceful degrade when unavailable) ---
LOCATION_ORS_API_KEY=
LOCATION_ORS_BASE_URL=https://api.openrouteservice.org
LOCATION_ENABLE_ORS_VALIDATION=true

# --- Provider Retry ---
LOCATION_PROVIDER_TIMEOUT_MS=4000
LOCATION_PROVIDER_RETRY_MAX=3

# --- Segment & Elevation ---
LOCATION_SEGMENT_MAX_LENGTH_M=200
LOCATION_ELEVATION_SAMPLING_MAX_SPACING_M=30
LOCATION_ELEVATION_MAX_TILES=2000

# --- Validation Thresholds ---
LOCATION_DISTANCE_DELTA_WARNING_PCT=5.0
LOCATION_DISTANCE_DELTA_FAIL_PCT=15.0
LOCATION_DURATION_DELTA_WARNING_PCT=10.0
LOCATION_DURATION_DELTA_FAIL_PCT=20.0
LOCATION_ENDPOINT_PARITY_TOLERANCE_M=25.0
LOCATION_KNOWN_SPEED_LIMIT_RATIO_WARNING=0.85
LOCATION_KNOWN_SPEED_LIMIT_RATIO_FAIL=0.50

# --- Hard Delete ---
LOCATION_HARD_DELETE_GRACE_PERIOD_DAYS=30

# --- Idempotency ---
LOCATION_IDEMPOTENCY_TTL_HOURS=24

# --- Stuck Run Recovery ---
LOCATION_RUN_STUCK_SLA_MINUTES=30

# --- Object Storage ---
LOCATION_STORAGE_BACKEND=local
LOCATION_STORAGE_LOCAL_PATH=./storage
LOCATION_IMPORT_STORAGE_BUCKET=
LOCATION_EXPORT_STORAGE_BUCKET=
LOCATION_EXPORT_FILE_TTL_HOURS=24

# --- Bulk Refresh ---
LOCATION_ENABLE_BULK_REFRESH=true
LOCATION_MONTHLY_REFRESH_CRON=
