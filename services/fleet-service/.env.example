# Fleet Service — Environment Variables
# Copy to .env and fill in values

# Service
FLEET_SERVICE_NAME=fleet-service
FLEET_SERVICE_PORT=8102
FLEET_ENVIRONMENT=dev

# Database
FLEET_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fleet_service

# Auth (CHANGE IN PRODUCTION)
FLEET_AUTH_JWT_ALGORITHM=RS256
FLEET_AUTH_ISSUER=lojinext-platform
FLEET_AUTH_AUDIENCE=lojinext-platform
FLEET_AUTH_PUBLIC_KEY=
FLEET_AUTH_PRIVATE_KEY=
FLEET_AUTH_JWKS_URL=http://localhost:8105/.well-known/jwks.json
FLEET_AUTH_JWKS_CACHE_TTL_SECONDS=300
FLEET_AUTH_SERVICE_TOKEN_URL=http://localhost:8105/auth/v1/token/service
FLEET_AUTH_SERVICE_CLIENT_ID=fleet-service
FLEET_AUTH_SERVICE_CLIENT_SECRET=

# Feature flags
FLEET_ENABLE_HARD_DELETE=false
FLEET_ENABLE_TRIP_REFERENCES=false

# Dependencies — Driver Service
FLEET_DRIVER_SERVICE_BASE_URL=http://localhost:8104

# Dependencies — Trip Service
FLEET_TRIP_SERVICE_BASE_URL=http://localhost:8101

# HTTP Client
FLEET_HTTP_CONNECT_TIMEOUT=0.5
FLEET_HTTP_READ_TIMEOUT=0.8
FLEET_HTTP_TOTAL_TIMEOUT=1.5

# Outbox
FLEET_OUTBOX_POLL_INTERVAL_SECONDS=5
FLEET_OUTBOX_BATCH_SIZE=50
FLEET_OUTBOX_MAX_RETRIES=5
FLEET_OUTBOX_WORKER_ENABLED=true

# Pagination
FLEET_DEFAULT_PAGE_SIZE=20
FLEET_MAX_PAGE_SIZE=100

# Broker
# FLEET_BROKER_TYPE=    (auto: prod=kafka, test=noop, dev=log)
FLEET_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
FLEET_KAFKA_TOPIC=fleet.events.v1
FLEET_KAFKA_CLIENT_ID=fleet-service
FLEET_KAFKA_SECURITY_PROTOCOL=PLAINTEXT
